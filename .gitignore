# All generated output — CSVs, logs, SQL scripts, healthcheck folders, install logs
# Never commit runtime output; re-generate from scripts as needed
output-files/

# PowerShell artefacts
*.ps1.bak

# Windows
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
